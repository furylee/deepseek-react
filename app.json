{
  "expo": {
    "name": "DeepSeek Custom",
    "slug": "deepseek-custom-api-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "deepseekcustom",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.deepseekcustom.apiapp"
    },
